{
  "name": "conceps-wa",
  "version": "1.0.0",
  "private": true,
  "description": "Conceps WA — WhatsApp CRM and automation platform for agencies",
  "license": "MIT",
  "author": "Conceps",
  "homepage": "https://github.com/your-org/conceps-wa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/conceps-wa.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/conceps-wa/issues"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.7",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "turbo": "^2.10.5",
    "prettier": "^3.9.1",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "ip-address": "^10.1.1",
    "fast-uri": "^3.1.2",
    "hono": "^4.12.25",
    "js-yaml": "^4.2.0",
    "@babel/core": "^7.29.6"
  }
}
