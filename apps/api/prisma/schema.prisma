generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

model Account {
  id                            String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                          String
  ownerUserId                   String                          @unique(map: "idx_accounts_one_per_owner") @map("owner_user_id") @db.Uuid
  createdAt                     DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime                        @default(now()) @map("updated_at") @db.Timestamptz(6)
  defaultCurrency               String                          @default("USD") @map("default_currency")
  account_invitations           account_invitations[]
  users                         users                           @relation(fields: [ownerUserId], references: [id], onUpdate: NoAction)
  ai_configs                    ai_configs?
  ai_knowledge_chunks           ai_knowledge_chunks[]
  ai_knowledge_documents        ai_knowledge_documents[]
  apiKeys                       ApiKey[]
  automationLogs                AutomationLog[]
  automationPendingExecutions   AutomationPendingExecution[]
  automations                   Automation[]
  broadcasts                    broadcasts[]
  contact_notes                 contact_notes[]
  contacts                      contacts[]
  conversations                 conversations[]
  custom_fields                 custom_fields[]
  deals                         deals[]
  flowRuns                      FlowRun[]
  flows                         Flow[]
  member_presence               member_presence[]
  message_templates             message_templates[]
  notifications                 notifications[]
  pipelines                     pipelines[]
  profiles                      Profile[]
  tags                          tags[]
  webhook_endpoints             webhook_endpoints[]
  whatsapp_config               whatsapp_config?
  whatsapp_orders               whatsapp_orders[]
  whatsapp_products             whatsapp_products[]

  @@map("accounts")
  @@schema("public")
}

model Profile {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String      @unique @map("user_id") @db.Uuid
  fullName     String      @map("full_name")
  email        String
  avatarUrl    String?     @map("avatar_url")
  role         String?     @default("user")
  createdAt    DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?   @default(now()) @map("updated_at") @db.Timestamptz(6)
  betaFeatures String[]    @default([]) @map("beta_features")
  accountId    String      @map("account_id") @db.Uuid
  accountRole  AccountRole @map("account_role")
  deals        deals[]
  account      Account     @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        users       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([accountId, accountRole], map: "idx_profiles_account_role")
  @@map("profiles")
  @@schema("public")
}

model ApiKey {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId  String    @map("account_id") @db.Uuid
  createdBy  String?   @map("created_by") @db.Uuid
  name       String
  keyPrefix  String    @map("key_prefix")
  keyHash    String    @unique @map("key_hash")
  scopes     String[]  @default([])
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  account    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [createdBy], references: [id], onUpdate: NoAction)

  @@index([accountId])
  @@index([keyHash])
  @@map("api_keys")
  @@schema("public")
}

