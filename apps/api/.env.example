# ============================================================
# REQUIRED
# ============================================================

# Session-mode Supavisor pooler connection string for the `prisma`
# role (see prisma/bootstrap-role.sql — run that SQL once in the
# Supabase SQL editor first, then paste the resulting password here).
# Port 5432, NOT 6543 — this is a persistent Node process, not
# serverless, so no separate DIRECT_URL is needed.
DATABASE_URL="postgres://prisma.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres?connection_limit=10"

# Same Supabase project apps/web already points at (Project Settings -> API).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Reserved for Phase 1+ (Storage/Realtime admin access from apps/api).
# Not used by anything in Phase 0.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Confirmed via live testing: this project uses asymmetric ES256
# signing keys (Supabase Dashboard -> Settings -> API -> JWT Settings)
# — no secret needed, SupabaseAuthGuard fetches the public JWKS
# instead. Only set SUPABASE_JWT_SECRET (and switch this to HS256) if
# a future/other project uses the legacy shared-secret setup instead.
SUPABASE_JWT_ALG=ES256
# SUPABASE_JWT_SECRET=your-jwt-secret

# WhatsApp token encryption key (Automations domain, Phase 1) — must be
# the SAME 64-hex-char key apps/web uses, since it decrypts
# whatsapp_config.access_token rows encrypted by apps/web.
ENCRYPTION_KEY=your-64-char-hex-key-here

# Shared secret for the apps/web -> apps/api server-to-server bridge
# (e.g. the WhatsApp webhook's automations dispatch call). Generate with:
#   openssl rand -hex 32
# Must match apps/web's INTERNAL_API_SECRET exactly.
INTERNAL_API_SECRET=generate-a-long-random-string

# ============================================================
# RECOMMENDED — safe defaults for local dev
# ============================================================

# docker-compose up starts this at the root of the repo.
REDIS_URL=redis://localhost:6379

PORT=8001
NODE_ENV=development

# BullMQ automations-pending worker concurrency (default 5 if unset).
# AUTOMATIONS_WORKER_CONCURRENCY=5
